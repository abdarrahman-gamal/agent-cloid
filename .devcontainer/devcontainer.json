{
  "name": "OpenCode Webtop GUI",
  "image": "lscr.io/linuxserver/webtop:ubuntu-xfce",

  // تحويل خيارات --security-opt و --shm-size
  "runArgs": [
    "--security-opt", "seccomp=unconfined",
    "--shm-size=2gb"
  ],

  // تحويل المتغيرات البيئية -e
  "containerEnv": {
    "PUID": "1000",
    "PGID": "1000",
    "TZ": "Africa/Cairo"
  },

  // تحويل البورت -p 3000:3000
  "forwardPorts": [3000],

  "portsAttributes": {
    "3000": {
      "label": "OpenCode Desktop (Webtop)",
      "onAutoForward": "openBrowser"
    }
  },

  // تثبيت OpenCode تلقائياً داخل الـ Webtop عند التشغيل
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y wget && wget -O opencode.deb https://opencode.ai/download/stable/linux-x64-deb && sudo apt-get install -y ./opencode.deb && rm opencode.deb"
}
